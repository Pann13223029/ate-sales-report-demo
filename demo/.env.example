# Legacy note: this env template belongs to the older LINE/Python demo path.
# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (fallback)
GROQ_API_KEY=your_groq_api_key_here

# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=your_service_account_json_here
SHEETS_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id_here/edit

# Looker Studio
DASHBOARD_URL=https://lookerstudio.google.com/reporting/your_dashboard_id_here
